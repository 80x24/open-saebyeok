# === 채널 선택 ===
# 비워두면 Claude Code 셋업 위자드(identity/SETUP.md)가 대화로 채워줍니다.
CHANNEL=                    # telegram | slack

# --- 텔레그램 (CHANNEL=telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=           # 본인 chat id (이 사람만 봇이 응답)

# --- 슬랙 (CHANNEL=slack) ---
SLACK_BOT_TOKEN=           # xoxb-...
SLACK_APP_TOKEN=           # xapp-... (Socket Mode)
SLACK_OWNER_ID=            # 본인 Slack user id

# === 하트비트 (자율 루틴 — 기본 OFF) ===
# 설정하면 그 주기로 HEARTBEAT.md 지침을 자동 실행합니다. 비우면 비활성.
# HEARTBEAT_CRON=0 */2 * * *   # 예: 2시간마다

# === 선택 (기본값 있음) ===
# CLAUDE_HOME=             # 기본 ~/.claude
# CLAUDE_MODEL=opus
# CLAUDE_TIMEOUT_MS=1800000

# ⚠️ ANTHROPIC_API_KEY 를 여기 넣지 마세요.
#    이게 설정되면 구독 대신 '종량제(API 과금)'로 청구됩니다.
#    봇은 spawn 시 자동 제거하지만, 셸/다른 스크립트에서 export 하지 않도록 주의하세요.
